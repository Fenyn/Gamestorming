size_flags_horizontal = 3
theme_override_constants/separation = 2

[node name="TopLine" type="HBoxContainer" parent="MarginContainer/HBox/InfoVBox"]
layout_mode = 2

[node name="NameLabel" type="Label" parent="MarginContainer/HBox/InfoVBox/TopLine"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 14
text = "Heartmotes"

[node name="CountLabel" type="Label" parent="MarginContainer/HBox/InfoVBox/TopLine"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "x0"
horizontal_alignment = 2

[node name="ProductionLabel" type="Label" parent="MarginContainer/HBox/InfoVBox"]

; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Worldseed"
config/description="Terraform an alien planet by farming exotic crops. Manage power, deploy nanobot bees, and watch a barren rock become a living world."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://scripts/autoload/event_bus.gd"
GameState="*res://scripts/autoload/game_state.gd"
TickEngine="*res://scripts/autoload/tick_engine.gd"
PlotManager="*res://scripts/autoload/plot_manager.gd"
BeeManager="*res://scripts/autoload/bee_manager.gd"
TerraformManager="*res://scripts/autoload/terraform_manager.gd"
MilestoneManager="*res://scripts/autoload/milestone_manager.gd"
PowerManager="*res://scripts/autoload/power_manager.gd"
O2Manager="*res://scripts/autoload/o2_manager.gd"
BuildManager="*res://scripts/autoload/build_manager.gd"
WorldProgressor="*res://scripts/autoload/world_progressor.gd"
SoundManager="*res://scripts/autoload/sound_manager.gd"
StationUtils="*res://scripts/autoload/station_utils.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="Worldseed"

[input]

move_forward={

[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/generator_row.gd" id="1"]

[node name="GeneratorRow" type="PanelContainer"]
custom_minimum_size = Vector2(0, 60)
script = ExtResource("1")

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 14
theme_override_constants/margin_top = 4
theme_override_constants/margin_right = 8
theme_override_constants/margin_bottom = 4

[node name="HBox" type="HBoxContainer" parent="MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="InfoVBox" type="VBoxContainer" parent="MarginContainer/HBox"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 1

[node name="TopLine" type="HBoxContainer" parent="MarginContainer/HBox/InfoVBox"]
layout_mode = 2

[node name="NameLabel" type="Label" parent="MarginContainer/HBox/InfoVBox/TopLine"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 14
text = "Heartmotes"

[node name="CountLabel" type="Label" parent="MarginContainer/HBox/InfoVBox/TopLine"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 12
text = "0 owned"
horizontal_alignment = 2

[node name="ProductionLabel" type="Label" parent="MarginContainer/HBox/InfoVBox"]
